#include <WiFi.h>
#include <WiFiClientSecure.h>
#include <PubSubClient.h>

const char* ssid = "PC";
const char* password = "aliali786";
const char* mqtt_server = "e51ea384284c45198861d187a9d55cbe.s1.eu.hivemq.cloud";
const char* mqtt_user = "236034";
const char* mqtt_pass = "Fast6034";
const int mqtt_port = 8883;

WiFiClientSecure espClient;
PubSubClient client(espClient);

// ✅ Callback function - fires whenever a message is received
void callback(char* topic, byte* payload, unsigned int length) {
  Serial.print("Message received on topic [");
  Serial.print(topic);
  Serial.print("]: ");

  String message = "";
  for (unsigned int i = 0; i < length; i++) {
    message += (char)payload[i];
  }

  Serial.println(message);
}

void setup_wifi() {
  Serial.print("Connecting to WiFi...");
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\nWiFi Connected!");
}

void reconnect() {
  while (!client.connected()) {
    Serial.print("Connecting to MQTT...");
    String clientId = "ESP32Subscriber-" + String(random(0xffff), HEX);

    if (client.connect(clientId.c_str(), mqtt_user, mqtt_pass)) {
      Serial.println("Connected to HiveMQ!");

      // ✅ Subscribe to the SAME topic the publisher uses
      client.subscribe("Esp32/Assignment-2");
      Serial.println("Subscribed to: Esp32/Assignment-2");

    } else {
      Serial.print("Failed, rc=");
      Serial.print(client.state());
      Serial.println(" - Retrying in 5 seconds...");
      delay(5000);
    }
  }
}

void setup() {
  Serial.begin(115200);
  setup_wifi();

  espClient.setInsecure();
  client.setServer(mqtt_server, mqtt_port);

  // ✅ Register the callback BEFORE connecting
  client.setCallback(callback);
}

void loop() {
  if (!client.connected()) {
    reconnect();
  }

  // ✅ Must call loop() to process incoming messages
  client.loop();
}
```

Here's what was changed and why:

**1. Added `callback()` function**
This is the core fix. PubSubClient requires you to define a function that gets called automatically when a message arrives. It receives the topic, raw byte payload, and length.

**2. Registered callback with `client.setCallback(callback)`**
Called in `setup()` before connecting — this wires the function to the MQTT client.

**3. Fixed the topic** — your original subscriber was listening to `"test/topic"` but the publisher sends to `"Esp32/Assignment-2"`. Now both match.

**4. Removed the publish block from `loop()`** — a subscriber doesn't need to publish anything; keeping it clean avoids confusion.

**5. Matched WiFi credentials** to your publisher (`"PC"` / `"aliali786"`).

