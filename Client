#include <WiFi.h>
#include <WiFiClientSecure.h>
#include <PubSubClient.h>

// 1. Enter your credentials
const char* ssid = "YOUR_WIFI_SSID";
const char* password = "YOUR_WIFI_PASSWORD";
const char* mqtt_server = "e51ea384284c45198861d187a9d55cbe.s1.eu.hivemq.cloud"; // Found in HiveMQ Console
const char* mqtt_user = "236034";
const char* mqtt_pass = "Fast6034";
const int mqtt_port = 8883;

WiFiClientSecure espClient;
PubSubClient client(espClient);

void setup_wifi() {
  Serial.print("Connecting to ");
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) { delay(500); }
}

void reconnect() {
  while (!client.connected()) {
    String clientId = "ESP32Client-" + String(random(0xffff), HEX);
    if (client.connect(clientId.c_str(), mqtt_user, mqtt_pass)) {
      client.subscribe("test/topic");
    } else { delay(5000); }
  }
}

void setup() {
  Serial.begin(115200);
  setup_wifi();
  // Required for HiveMQ Cloud: Skip cert validation for testing
  espClient.setInsecure(); 
  client.setServer(mqtt_server, mqtt_port);
}

void loop() {
  if (!client.connected()) { reconnect(); }
  client.loop();
  // Example: Publish every 5 seconds
  static unsigned long lastMsg = 0;
  if (millis() - lastMsg > 5000) {
    lastMsg = millis();
    client.publish("test/topic", "Hello from ESP32");
  }
}
